# =============================================================================
# SERVER ENVIRONMENT VARIABLES — CR Announcement Dashboard
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
# Leave empty to use JSON file fallback (db.json) — not recommended for production.
DATABASE_URL=postgresql://postgres.zmqoqvubfskdukehnqos:iAh4UKz4AiIlKt0Y@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# --- JWT ---
# Generate a strong key: openssl rand -hex 64
JWT_SECRET=d4c1e21963a6d5d1119269b537b974e84fe1637f15ac4a7f3c0ec640c67aaa8e
JWT_EXPIRES_IN=24h

# --- Supabase Storage (optional — fallback to local uploads/) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET_NAME=announcement-files

# --- Telegram Bot (optional — mock mode if empty) ---
TELEGRAM_BOT_TOKEN=

# --- SMTP (optional — password reset won't work if empty) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# --- File Settings ---
FILE_EXPIRY_DAYS=15
STORAGE_LIMIT_BYTES=104857600
IMAGE_QUALITY=80
PNG_COMPRESSION_LEVEL=9

# --- Puppeteer (Windows only) ---
PUPPETEER_EXECUTABLE_PATH=
