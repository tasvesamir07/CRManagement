# === Server Configuration ===
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed origins (no wildcard). Local dev: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# === Database (PostgreSQL) ===
# Leave empty to fallback to local JSON file database (db.json)
DATABASE_URL=

# === JWT Authentication ===
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_EXPIRES_IN=24h

# === Supabase Storage ===
# Leave empty to fallback to local file storage (server/uploads/)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET_NAME=Course

# === Telegram Integration ===
# Bot token from BotFather. Leave empty to use mock bot that logs messages.
TELEGRAM_BOT_TOKEN=

# === SMTP (Email) Configuration ===
# Used for password reset OTP, email verification, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# === File Expiry Configuration ===
FILE_EXPIRY_DAYS=15

# === WhatsApp Relay (optional) ===
# If using an external VPS relay for WhatsApp instead of Baileys directly
WHATSAPP_RELAY_URL=
WHATSAPP_RELAY_SECRET=

# === Canva Integration (optional) ===
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=

# === Logging ===
LOG_LEVEL=debug
