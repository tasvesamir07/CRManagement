# === Server Configuration ===
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# === Database (PostgreSQL) ===
# Example: postgresql://postgres:password@localhost:5432/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?sslmode=require

# === JWT Authentication ===
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=24h

# === Supabase Storage (Optional - Fallback to local files if empty) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET_NAME=announcement-files

# === Telegram Integration ===
# Bot token from BotFather. Leave empty to use mock bot that logs messages.
TELEGRAM_BOT_TOKEN=

# === SMTP (Email) Configuration ===
# Used for password reset OTP, email verification, etc.
# For Gmail, use an App Password (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=your-email@gmail.com

# === File Expiry Configuration ===
FILE_EXPIRY_DAYS=15

# === Storage Limit & Compression Settings ===
# Limit in bytes. Default is 104857600 (100MB). Set to 0 for unlimited.
STORAGE_LIMIT_BYTES=104857600
# Quality settings for Sharp images (0-100)
IMAGE_QUALITY=80
# Compression level for Sharp PNGs (0-9)
PNG_COMPRESSION_LEVEL=9

# === Puppeteer Configuration ===
# Override Chromium path if bundled browser fails to run (Windows issues)
# Example: C:\Program Files\Google\Chrome\Application\chrome.exe
PUPPETEER_EXECUTABLE_PATH=
